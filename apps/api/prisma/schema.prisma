generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageDirection {
  in
  out
}

enum MessageStatus {
  pending
  sent
  delivered
  failed
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedConversations Conversation[] @relation("AssignedManager")
}

model Contact {
  id         String   @id @default(uuid())
  channel    String   @default("telegram")
  // Telegram chat id (the client who wrote to the bot).
  externalId String
  name       String?
  username   String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  conversation Conversation?

  @@unique([channel, externalId])
}

model Conversation {
  id              String    @id @default(uuid())
  channel         String    @default("telegram")
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId       String    @unique
  // Manager (operator) assigned to handle this conversation.
  assignedTo      User?     @relation("AssignedManager", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId    String?
  lastMessageAt   DateTime?
  lastMessageText String?
  unreadCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages Message[]

  @@index([lastMessageAt])
  @@index([assignedToId])
}

model Message {
  id             String           @id @default(uuid())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  direction      MessageDirection
  text           String
  externalId     String?
  // For outgoing messages: which manager sent it.
  sentById       String?
  status         MessageStatus    @default(sent)
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}
