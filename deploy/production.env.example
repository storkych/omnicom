# Production .env for server (copy content into GitHub secret PRODUCTION_ENV)
# Domain: https://omnicanal.storkyproduct.ru

POSTGRES_USER=omnicom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=omnicom

DATABASE_URL=postgresql://omnicom:CHANGE_ME_STRONG_PASSWORD@postgres:5432/omnicom?schema=public
REDIS_URL=redis://redis:6379

API_PORT=4000
WEB_PORT=3000

# Same domain — nginx routes API paths to backend
NEXT_PUBLIC_API_URL=https://omnicanal.storkyproduct.ru
CORS_ORIGIN=https://omnicanal.storkyproduct.ru

JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRES_IN=7d
SESSION_ENC_KEY=CHANGE_ME_64_HEX_CHARS

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_PROXY_URL=

# Moscow server: use mirror if npm is slow during build
NPM_REGISTRY=https://registry.npmmirror.com
